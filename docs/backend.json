
{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "avatarUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's avatar image."
        },
        "companyLogoUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's company logo."
        },
        "role": {
          "type": "string",
          "enum": ["individual_creator", "talent", "agency_owner", "agency_admin", "agency_member"],
          "description": "The user's role in the application."
        },
        "isAgencyOwner": {
          "type": "boolean"
        },
        "hasCompletedOnboarding": {
          "type": "boolean"
        },
        "showInMarketplace": {
            "type": "boolean"
        },
        "niche": {
            "type": "string"
        },
        "contentType": {
            "type": ["string", "null"],
            "enum": ["Tech", "Fashion", "Comedy", "Gaming", "Lifestyle", "Food", null]
        },
        "giggingForAgencies": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "A list of agency IDs for which the creator has accepted a gig but is not yet official talent."
        },
        "instagramConnected": { "type": "boolean" },
        "instagramFollowers": { "type": "number" },
        "instagramEngagement": { "type": "number" },
        "tiktokConnected": { "type": "boolean" },
        "tiktokFollowers": { "type": "number" },
        "tiktokEngagement": { "type": "number" },
        "youtubeConnected": { "type": "boolean" },
        "youtubeFollowers": { "type": "number" },
        "youtubeEngagement": { "type": "number" },
        "averageVerzaScore": { "type": "number", "description": "The average quality score across all verified submissions." }
      },
      "required": ["uid", "email"]
    },
    "agency": {
      "title": "Agency",
      "description": "Represents an agency or brand entity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "availableBalance": { "type": "number", "description": "Funds available in the general wallet." },
        "escrowBalance": { "type": "number", "description": "Funds locked in active gigs." }
      }
    },
    "contract": {
      "title": "Contract",
      "description": "Represents a contract between a creator and a brand.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the contract."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the contract."
        },
        "brand": {
          "type": "string",
          "description": "The name of the brand associated with the contract."
        },
        "amount": {
          "type": "number",
          "description": "The total amount of the contract."
        },
        "dueDate": {
          "type": "string",
          "format": "date",
          "description": "The due date of the contract."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "paid", "overdue", "at_risk", "invoiced"],
          "description": "The status of the contract."
        }
      },
      "required": ["id", "userId", "brand", "amount", "dueDate", "status"]
    },
    "gig": {
      "title": "Gig",
      "description": "A project posted by a brand for creators to accept.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique identifier for the gig."
        },
        "brandId": {
          "type": "string",
          "description": "The UID of the user or agency that posted the gig."
        },
        "brandName": {
          "type": "string",
          "description": "The name of the brand."
        },
        "brandLogoUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL of the brand's logo."
        },
        "title": {
          "type": "string",
          "description": "The title of the gig."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the project requirements."
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["TikTok", "Instagram", "YouTube", "Facebook"]
          }
        },
        "ratePerCreator": {
          "type": "number",
          "description": "The amount to be paid to each creator who completes the gig."
        },
        "creatorsNeeded": {
          "type": "number",
          "description": "The total number of creators required for this gig."
        },
        "videosPerCreator": {
          "type": "number",
          "description": "The number of videos required from each creator."
        },
        "acceptedCreatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of UIDs of creators who have accepted the gig."
        },
        "paidCreatorIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of UIDs of creators who have been paid for this gig."
        },
        "fundingPaymentIntentId": {
          "type": "string",
          "description": "The Stripe PaymentIntent ID used to fund the gig."
        },
        "status": {
          "type": "string",
          "enum": ["pending_payment", "open", "in-progress", "completed"],
          "description": "The current status of the gig."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the gig was created."
        }
      },
      "required": ["id", "brandId", "brandName", "title", "description", "platforms", "ratePerCreator", "creatorsNeeded", "videosPerCreator", "status", "createdAt", "paidCreatorIds"]
    },
    "gigSubmission": {
      "title": "Gig Submission",
      "description": "A video submission from a creator for a specific gig.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gigId": { "type": "string" },
        "brandId": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "verzaScore": { "type": "number", "description": "The AI quality score (0-100)." },
        "verzaFeedback": { "type": "string", "description": "AI-generated feedback for the video." },
        "status": { "type": "string", "enum": ["pending_verza_score", "submitted", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "notification": {
      "title": "Notification",
      "description": "An in-app notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "The recipient's UID." },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["gig_accepted", "submission_received", "submission_approved", "payout_received", "system"] },
        "read": { "type": "boolean" },
        "link": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/userProfile"
      },
      "description": "Stores public user profile information."
    },
    "/contracts/{contractId}": {
      "schema": {
        "$ref": "#/backend/entities/contract"
      },
      "description": "Stores contract details and associated metadata."
    },
    "/gigs/{gigId}": {
      "schema": {
        "$ref": "#/backend/entities/gig"
      },
      "description": "Stores gig postings from brands for creators."
    },
    "/submissions/{submissionId}": {
      "schema": {
        "$ref": "#/backend/entities/gigSubmission"
      },
      "description": "Stores video submissions for gigs."
    },
    "/notifications/{notificationId}": {
      "schema": {
        "$ref": "#/backend/entities/notification"
      },
      "description": "Stores in-app notifications for users."
    },
    "/agencies/{agencyId}": {
      "schema": {
        "$ref": "#/backend/entities/agency"
      },
      "description": "Stores agency and brand organizational data."
    }
  }
}
