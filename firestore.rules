
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requester is the owner of a document
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    
    // Helper function to check if the requester is part of the specified agency via custom claims
    function isMemberOfAgency(agencyId) {
      return request.auth != null && request.auth.token.primaryAgencyId == agencyId;
    }

    // Helper to check if the user is a team member (owner, admin, or member) of the specified agency
    function isTeamMemberOf(agencyId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      // Check if user's primary agency matches and their role is one of the team roles
      return request.auth != null && 
             userDoc.get('primaryAgencyId', null) == agencyId &&
             (userDoc.get('role', 'none') == "agency_owner" || userDoc.get('role', 'none') == "agency_admin" || userDoc.get('role', 'none') == "agency_member");
    }

    // Helper to determine if the target user is a talent in the requester's agency
    function isTalentInMyAgency(targetUserId) {
      let requesterAgencyId = request.auth.token.get('primaryAgencyId', null);
      // If the requester doesn't belong to an agency, they can't have talent.
      return requesterAgencyId != null &&
             'talent' in get(/databases/$(database)/documents/agencies/$(requesterAgencyId)).data &&
             get(/databases/$(database)/documents/agencies/$(requesterAgencyId)).data.talent.exists(t, t.userId == targetUserId);
    }
    
    // Helper to check if a creator has accepted a gig for the requesting agency
    function isGigAffiliated(userId) {
      let requesterAgencyId = request.auth.token.get('primaryAgencyId', null);
       // Returns true only if requester has an agency AND the target user's profile has that agency in giggingForAgencies.
      return requesterAgencyId != null &&
             'giggingForAgencies' in get(/databases/$(database)/documents/users/$(userId)).data &&
             requesterAgencyId in get(/databases/$(database)/documents/users/$(userId)).data.get('giggingForAgencies', []);
    }

    // Helper to check if a user can access a receipt, either by being the owner
    // or by having access to the linked contract.
    function isAllowedToAccessReceipt(receipt) {
      // The user is the direct owner/creator of the receipt.
      let isDirectOwner = isOwner(receipt.userId);
      // The user has access to the contract this receipt is linked to.
      let hasAccessViaContract = receipt.get('linkedContractId', null) != null ? (request.auth.uid in get(/databases/$(database)/documents/contracts/$(receipt.linkedContractId)).data.get('access', {})) : false;
      
      return isDirectOwner || hasAccessViaContract;
    }

    // Rules for the users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isTalentInMyAgency(userId) || isGigAffiliated(userId) || resource.data.get('showInMarketplace', false) == true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
                       (
                         (request.resource.data.get('hasCompletedOnboarding', false) == true && resource.data.get('hasCompletedOnboarding', false) == false) ||
                         (
                           !(request.resource.data.get('role', 'none') != resource.data.get('role', 'none') && request.resource.data.get('role', 'none') == "agency_owner") &&
                           !(request.resource.data.get('isAgencyOwner', false) == true && resource.data.get('isAgencyOwner', false) == false)
                         )
                       );
      
      match /private_credentials/{credId} {
          allow read, write: if false; // Only backend functions
      }

      match /characters/{characterId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Rules for the contracts collection
    match /contracts/{contractId} {
        allow read: if isOwner(resource.data.userId) || request.auth.uid in resource.data.access;
        allow update, delete: if isOwner(resource.data.userId) || request.auth.uid in resource.data.access;
        allow create: if isOwner(request.resource.data.userId) || request.auth.uid in request.resource.data.access;
    }
    
    // Rules for video generations
    match /generations/{generationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update, delete: if false;
    }

    // Rules for gigs
    match /gigs/{gigId} {
      allow read: if request.auth != null;
      allow create: if isTeamMemberOf(request.resource.data.brandId);
      allow update: if (isTeamMemberOf(resource.data.brandId)) || (request.auth != null && resource.data.status == 'open');
      allow delete: if isTeamMemberOf(resource.data.brandId) && 
                      (resource.data.status == 'pending_payment' || 
                       (resource.data.status == 'open' && resource.data.acceptedCreatorIds.size() == 0));
    }

    // Rules for gig submissions
    match /submissions/{submissionId} {
      allow read: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || 
        isTeamMemberOf(resource.data.brandId)
      );
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && (
        (resource.data.creatorId == request.auth.uid && request.resource.data.brandId == resource.data.brandId) ||
        (isTeamMemberOf(resource.data.brandId))
      );
    }

    // Rules for notifications
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if request.auth != null; // Ideally restricted to backend but allowed for client-side triggered notifications
      allow delete: if isOwner(resource.data.userId);
    }

    // Rules for brand_research collection
    match /brand_research/{researchId} {
      allow read, update, delete: if isOwner(resource.data.uid);
      allow create: if isOwner(resource.data.uid);
    }
    
    // Rules for credit transactions collection
    match /credit_transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if false; // Only backend can write
    }

    match /paymentIntents/{intentId} {
      allow read: if isOwner(resource.data.userId) || isOwner(resource.data.creatorId);
      allow create, update, delete: if false;
    }
    
    // Rules for payments
    match /payments/{paymentId} {
       allow read: if isOwner(resource.data.userId) || isOwner(resource.data.creatorId);
      allow create, update, delete: if false;
    }
    
    match /emailLogs/{logId} {
      allow read: if resource.data.get('contractId', null) != null && 
                     get(/databases/$(database)/documents/contracts/$(resource.data.contractId)).data.access[request.auth.uid] != null;
      allow write: if false;
    }
    
    match /users/{userId}/bankAccounts/{accountId} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/bankTransactions/{transactionId} {
      allow read, write: if isOwner(userId);
    }
    
    match /receipts/{receiptId} {
      allow get, delete: if isAllowedToAccessReceipt(resource.data);
      allow list: if request.auth != null;
      allow create: if isAllowedToAccessReceipt(request.resource.data);
      allow update: if isAllowedToAccessReceipt(resource.data) && isAllowedToAccessReceipt(request.resource.data);
    }
    
    match /agencies/{agencyId} {
      allow read: if request.auth != null;
      allow create: if isOwner(request.resource.data.ownerId);
      allow update: if isMemberOfAgency(agencyId);
      allow delete: if get(/databases/$(database)/documents/agencies/$(agencyId)).data.ownerId == request.auth.uid;
    }
    
    match /internalPayouts/{payoutId} {
      allow read: if isMemberOfAgency(resource.data.agencyId) || isOwner(resource.data.talentId);
      allow create: if get(/databases/$(database)/documents/agencies/$(request.resource.data.agencyId)).data.ownerId == request.auth.uid || (request.auth.token.get('isAgencyAdmin', false) == true && request.auth.token.get('primaryAgencyId', '') == request.resource.data.agencyId);
      allow update, delete: if false;
    }
    
     match /agencyInvitations/{invitationId} {
        allow read: if request.auth.uid != null;
        allow write: if false;
     }
     
     match /teamInvitations/{invitationId} {
        allow read: if request.auth.uid != null;
        allow write: if false;
     }
  }
}
